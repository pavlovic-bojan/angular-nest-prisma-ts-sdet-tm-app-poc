# Task Manager API - Performance Test Config
# Copy to .env and set values (do not commit .env)

# Required: Backend URL (no trailing slash)
# Local: http://localhost:3000
BASE_URL=http://localhost:3000

# Optional: Login credentials (default: demo@example.com / password123)
# Must match backend seed (see backend/README.md)
LOGIN_EMAIL=demo@example.com
LOGIN_PASSWORD=password123
